{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/stock/:ticker", "destination": "/api/stock/[ticker]" },
    { "source": "/api/crypto/:ticker", "destination": "/api/crypto/[ticker]" },
    { "source": "/api/fundamentals/:ticker", "destination": "/api/fundamentals/[ticker]" },
    { "source": "/api/fng", "destination": "/api/fng" }
  ]
}
