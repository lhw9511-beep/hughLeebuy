{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/stock/(.+)", "dest": "/api/stock/[ticker]" },
    { "src": "/api/crypto/(.+)", "dest": "/api/crypto/[ticker]" },
    { "src": "/api/fundamentals/(.+)", "dest": "/api/fundamentals/[ticker]" },
    { "src": "/api/fng", "dest": "/api/fng" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
