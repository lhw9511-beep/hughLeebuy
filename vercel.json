{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/stock/:ticker", "destination": "/api/stock/[ticker]" },
    { "source": "/api/fundamentals/:ticker", "destination": "/api/fundamentals/[ticker]" },
    { "source": "/ranking.html", "destination": "/ranking.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
